# Cloudflare Pages — custom headers (copy to site root as `_headers` via Trunk `public/`).
# Production: Pages applies these on every response that matches the path pattern.
# COOP/COEP unlock SharedArrayBuffer for advanced WASM (e.g. threaded SQLite / workers).
# WARNING: require-corp means cross-origin assets need CORP/CORS; keep fonts/JS/WASM same-origin or crossorigin-compatible.
/*
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Embedder-Policy: require-corp
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin

/favicon.svg
  Cache-Control: public, max-age=86400, immutable

/favicon-32.png
  Cache-Control: public, max-age=86400, immutable

/fonts/*
  Cache-Control: public, max-age=31536000, immutable

/*.wasm
  Cache-Control: public, max-age=31536000, immutable
  Content-Type: application/wasm

/*.js
  Cache-Control: public, max-age=31536000, immutable

/*.css
  Cache-Control: public, max-age=31536000, immutable

/*.woff2
  Cache-Control: public, max-age=31536000, immutable

# HTML and JSON stay short-lived so text deploys are not stuck behind CDN.
/*.html
  Cache-Control: public, max-age=300, must-revalidate

# Brotli: Cloudflare compresses responses automatically when enabled; generate .br sidecars only if you use
# a worker or custom cache rules to serve them with Content-Encoding: br.
